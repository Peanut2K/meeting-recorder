      "id": "bug-001",
      "timestamp": "2026-06-26T00:00:00Z",
      "error_message": "infinite recursion detected in policy for relation \"team_members\"",
      "file": "supabase/migrations/001_initial_schema.sql",
      "root_cause": "RLS policies on public.team_members (team_members_select/insert/delete) ran a subquery against public.team_members itself. Evaluating that subquery re-triggers the same policy, causing Postgres to loop forever. teams_member_select, meetings_team_member, and templates_team_member also subquery team_members and would hit the same loop.",
      "fix": "Created supabase/migrations/002_fix_rls_recursion.sql: added SECURITY DEFINER helper functions is_team_member(uuid) and is_team_admin(uuid) (they bypass RLS for the inner read), then rewrote the recursive policies to call the helpers instead of subquerying team_members directly.",
      "tags": [
        "supabase",
        "rls",
        "postgres",
        "recursion",
        "policy",
        "team_members"
      ],
      "related_bugs": [],
      "occurrences": 1,
      "last_seen": "2026-06-26T00:00:00Z"
    },
